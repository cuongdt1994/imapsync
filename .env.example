# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-to-a-fernet-key

# Auth (change the password!)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# Path to imapsync binary
IMAPSYNC_PATH=/usr/bin/imapsync

# Max simultaneous migrations (2-4 recommended)
MAX_CONCURRENT_JOBS=3

# Number of reconnect attempts when a network connection drops
IMAPSYNC_RECONNECT_RETRIES=5

# Max runtime per job in seconds before the watchdog kills it
# Default: 86400 (24 hours).  Set higher for very large mailboxes.
IMAPSYNC_MAX_RUNTIME_SECONDS=86400

# How many days to keep logs
LOG_RETENTION_DAYS=30

# Timezone for display
TIMEZONE=Asia/Ho_Chi_Minh

# Set to 1 for development
DEBUG=0
